<mxfile host="app.diagrams.net">
  <diagram id="architecture" name="Architecture">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="web" value="Next.js" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="api" value="FastAPI modular monolith" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="80" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="data" value="PostgreSQL + Redis" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="web-api" edge="1" parent="1" source="web" target="api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="api-data" edge="1" parent="1" source="api" target="data">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
