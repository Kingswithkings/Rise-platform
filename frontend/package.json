    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.6.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
