<mxfile host="app.diagrams.net">
  <diagram id="deployment" name="Deployment">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="compose" value="Docker Compose" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="services" value="Frontend + Backend" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="stores" value="PostgreSQL + Redis" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="80" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="compose-services" edge="1" parent="1" source="compose" target="services">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="services-stores" edge="1" parent="1" source="services" target="stores">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
